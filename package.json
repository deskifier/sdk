{
  "name": "@deskifier/sdk",
  "version": "0.1.0-alpha.1",
  "description": "TypeScript SDK for building apps on the Deskifier desktop platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "docs:build": "typedoc"
  },
  "keywords": [
    "deskifier",
    "electron",
    "desktop",
    "sdk",
    "bubble"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tim12333/deskifier.git",
    "directory": "sdk"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "rimraf": "^5.0.5",
    "typedoc": "^0.25.7",
    "typedoc-plugin-markdown": "^3.17.1"
  }
}
